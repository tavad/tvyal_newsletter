# Updated parsing function
get_petrol_price_table <- function(oil_price_link) {
petrol_html <- read_html(oil_price_link)
petrol_info_line <- petrol_html |>
html_elements(".tarif-coll-list") |>
html_text()
final_table <-
tibble(
petrol_info_line = petrol_info_line
) |>
mutate(
petrol_info_line = str_replace_all(petrol_info_line, " ?դրամ", " դրամ"),
petrol_info_line = str_replace_all(petrol_info_line, " ?շուտով", " շուտով"),
) |>
unnest_regex(
"petrol_info_line", petrol_info_line,
pattern = " դրամ| շուտով"
) |>
mutate(
petrol_info_line = str_replace_all(petrol_info_line, "1l ?", " 1լ "),
petrol_info_line = str_replace_all(petrol_info_line, "1լ ?", " 1լ "),
petrol_info_line = str_remove_all(petrol_info_line, "1լ") |>
str_trim() |>
str_replace_all("[\\s\\n]+", " ")
) |>
extract(
petrol_info_line, into = c("petrol", "liter_price"),
regex = "(.*) (\\d+)$"
) |>
mutate(
date = today(),
liter_price = parse_number(liter_price)
) |>
filter(!is.na(petrol)) |>
relocate(date)
return(final_table)
}
# Updated safe scraping function using the new parsing
safe_scrape_petrol_prices <- function(url) {
tryCatch({
# Use the new parsing function
petrol_price <- get_petrol_price_table(url)
# Check if extraction was successful
if (nrow(petrol_price) == 0 || any(is.na(petrol_price$liter_price))) {
stop("Failed to extract petrol prices correctly")
}
# Get HTML for logging
petrol_html <- read_html(url)
return(list(success = TRUE, data = petrol_price, html = petrol_html))
}, error = function(e) {
# Attempt to get HTML even in case of error
tryCatch({
petrol_html <- read_html(url)
}, error = function(e2) {
petrol_html <- NULL
})
return(list(success = FALSE, error = as.character(e), html = petrol_html))
})
}
